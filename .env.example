# ---- Database (required) ----
# Postgres connection string. Any Postgres works (local, Neon, Supabase, etc.).
# Neon example: postgresql://user:password@ep-xxx.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ---- AI categorization (optional) ----
# OpenRouter API key. If unset, entries fall back to the local keyword categorizer.
OPENROUTER_API_KEY=
# Model slug used for categorization. Defaults to tencent/hy3:free when unset.
OPENROUTER_MODEL=tencent/hy3:free
# Sent as the HTTP-Referer header to OpenRouter. Defaults to https://steady.app.
OPENROUTER_REFERER=https://steady.app

# ---- Email (optional) ----
# Resend API key. If unset, email sending is a no-op (the notification is still logged).
RESEND_API_KEY=
# From address for outgoing email. Defaults to "Steady <steady@resend.dev>".
EMAIL_FROM=Steady <steady@resend.dev>

# ---- Cron (required for the scheduled routes) ----
# Shared secret. Cron routes reject any request without "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# ---- App URL (optional) ----
# Absolute URL used in email links. Defaults to https://steady.app.
NEXT_PUBLIC_APP_URL=http://localhost:3000
